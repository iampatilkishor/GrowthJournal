# Supabase — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — set to your Vercel domain after deployment
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Upstox broker (optional — only needed for live order features)
UPSTOX_API_KEY=your-upstox-api-key
UPSTOX_API_SECRET=your-upstox-api-secret
UPSTOX_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback
