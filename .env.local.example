# ── Broker Selection ─────────────────────────────────────────────────────────
# Set to "upstox" or "zerodha". Default is upstox if not set.
BROKER=upstox

# Expose broker to the frontend (for instrument token hints in the Order page)
NEXT_PUBLIC_BROKER=upstox

# ── Upstox Credentials ────────────────────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── Zerodha / Kite Connect Credentials ───────────────────────────────────────
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
# Zerodha uses the same redirect URI — register it in the Kite Developer Console
# UPSTOX_REDIRECT_URI is not needed when BROKER=zerodha

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
